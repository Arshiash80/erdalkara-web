# --- Site ---
# Canonical production URL (no trailing slash). Used for SEO: metadataBase,
# canonical/OG/Twitter tags, sitemap.xml and robots.txt. Falls back to
# https://erdalkara.com.tr when unset.
NEXT_PUBLIC_SITE_URL=https://erdalkara.com.tr

# --- Payload ---
# Generate a long random string, e.g.  openssl rand -base64 32
PAYLOAD_SECRET=

# --- Database (Neon Postgres) ---
# Use the pooled connection string from Neon. Include ?sslmode=require
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Media storage (Cloudflare R2, S3-compatible) ---
# Leave R2_* blank to fall back to local-disk uploads in development.
R2_BUCKET=
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: public bucket / custom domain base URL for serving files directly
R2_PUBLIC_URL=
